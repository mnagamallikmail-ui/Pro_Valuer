# ==============================================================================
# BwVrBackend - Environment Variables Template for VPS Deployment
# ==============================================================================
# Copy this file as .env and fill in all values before running the backend.
# NEVER commit the filled .env to version control.
# ==============================================================================

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://DB_HOST:5432/DB_NAME
SPRING_DATASOURCE_USERNAME=DB_USER
SPRING_DATASOURCE_PASSWORD=DB_PASSWORD

# ─── JPA / Hibernate Schema ───────────────────────────────────────────────────
SPRING_JPA_PROPERTIES_HIBERNATE_DEFAULT_SCHEMA=bwvr

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# CRITICAL: Generate a strong random secret (minimum 64 characters)
# Example: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_RANDOM_SECRET

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Example: https://yourfrontend.com,http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ─── Server Port ──────────────────────────────────────────────────────────────
PORT=8080

# ─── Storage Paths ────────────────────────────────────────────────────────────
# These default to /app/* inside Docker; override if using different mount points
BWVR_UPLOAD_DIR=/app/uploads
BWVR_TEMPLATE_DIR=/app/templates
BWVR_REPORT_OUTPUT_DIR=/app/reports
