# ==============================================================================
# BwVrFrontend (Flutter Web) - Environment Variables Template for VPS Deployment
# ==============================================================================
# These variables are passed as --dart-define flags at Flutter build time.
# Example build command:
#   flutter build web --release --pwa-strategy=none \
#     --dart-define=API_BASE_URL=https://your-backend.com/api/v1/ \
#     --dart-define=SWAGGER_URL=https://your-backend.com/swagger-ui.html \
#     --dart-define=HEALTH_URL=https://your-backend.com/actuator/health
# ==============================================================================

# ─── Backend API URL ──────────────────────────────────────────────────────────
# Must include trailing slash
API_BASE_URL=http://localhost:8080/api/v1/

# ─── Swagger UI URL ───────────────────────────────────────────────────────────
SWAGGER_URL=http://localhost:8080/swagger-ui.html

# ─── Actuator Health URL ──────────────────────────────────────────────────────
HEALTH_URL=http://localhost:8080/actuator/health
